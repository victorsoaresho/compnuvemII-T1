generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(150)
  email    String  @db.VarChar(150)
  document String  @unique @db.VarChar(20)
  orders   Order[]

  @@map("customer")
}

model Seller {
  id     Int     @id
  name   String  @db.VarChar(150)
  city   String  @db.VarChar(100)
  state  String  @db.Char(2)
  orders Order[]

  @@map("seller")
}

model Category {
  id            String        @id @db.VarChar(20)
  name          String        @db.VarChar(100)
  subCategories SubCategory[]

  @@map("category")
}

model SubCategory {
  id         String    @id @db.VarChar(20)
  name       String    @db.VarChar(100)
  categoryId String    @db.VarChar(20)
  category   Category  @relation(fields: [categoryId], references: [id])
  products   Product[]

  @@map("sub_category")
}

model Product {
  id            Int         @id @default(autoincrement())
  productId     Int         @unique
  productName   String      @db.VarChar(200)
  unitPrice     Decimal     @db.Decimal(12, 2)
  subCategoryId String      @db.VarChar(20)
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])
  orderItems    OrderItem[]

  @@map("product")
}

model Order {
  uuid       String      @id @db.VarChar(50)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp()
  indexedAt  DateTime    @map("indexed_at") @db.Timestamp()
  channel    String      @db.VarChar(50)
  total      Decimal     @db.Decimal(12, 2)
  status     String      @db.VarChar(20)
  customerId Int         @map("customer_id")
  customer   Customer    @relation(fields: [customerId], references: [id])
  sellerId   Int         @map("seller_id")
  seller     Seller      @relation(fields: [sellerId], references: [id])
  shipment   Shipment?
  payment    Payment?
  items      OrderItem[]
  source     String      @db.VarChar(50)
  userAgent  String      @map("user_agent") @db.Text
  ipAddress  String      @map("ip_address") @db.VarChar(45)

  @@map("orders")
}

model Shipment {
  id           Int    @id @default(autoincrement())
  orderUuid    String @unique @map("order_uuid") @db.VarChar(50)
  order        Order  @relation(fields: [orderUuid], references: [uuid])
  carrier      String @db.VarChar(100)
  service      String @db.VarChar(50)
  status       String @db.VarChar(50)
  trackingCode String @map("tracking_code") @db.VarChar(100)

  @@map("shipment")
}

model Payment {
  id            Int    @id @default(autoincrement())
  orderUuid     String @unique @map("order_uuid") @db.VarChar(50)
  order         Order  @relation(fields: [orderUuid], references: [uuid])
  method        String @db.VarChar(50)
  status        String @db.VarChar(50)
  transactionId String @map("transaction_id") @db.VarChar(100)

  @@map("payment")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderUuid   String  @map("order_uuid") @db.VarChar(50)
  order       Order   @relation(fields: [orderUuid], references: [uuid])
  productId   Int     @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  productName String  @map("product_name") @db.VarChar(200)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  quantity    Int
  total       Decimal @db.Decimal(12, 2)

  @@map("order_item")
}
